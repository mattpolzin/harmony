. ../setup.sh
. ./setup.sh

echo 'no subcommand:'
$harmony --bash-completion -- -- harmony

#
# version command
#
echo ''
echo 'version command'
echo ''
$harmony --bash-completion version -- version

#
# config command
#
echo ''
echo 'config command'
echo ''
echo 'no args suggests all settable props:'
$harmony --bash-completion config -- config

echo ''
echo 'options for requestTeams config:'
$harmony --bash-completion config -- requestTeams

echo ''
echo 'options for commentOnRequest config:'
$harmony --bash-completion config -- commentOnRequest

echo ''
echo 'options for bugfixPRTitlePrefix config:'
$harmony --bash-completion config -- bugfixPRTitlePrefix

echo ''
echo 'options for defaultProject config:'
$harmony --bash-completion config -- defaultProject

#
# pr command
#
echo ''
echo 'pr command'
echo ''
echo 'no args suggests print-tree, into, output, ready, draft, and issue args:'
$harmony --bash-completion pr -- pr

echo ''
echo 'draft pr suggests into, issue, output, and print-tree args:'
$harmony --bash-completion pr -- --draft

echo ''
echo 'into pr suggests draft, issue, output, and print-tree args:'
$harmony --bash-completion pr -- main

echo ''
echo 'ready pr suggests issue, into, output, and print-tree args:'
$harmony --bash-completion pr -- --ready

echo ''
echo 'output last arg suggests draft, issue, into, and print-tree args:'
$harmony --bash-completion pr -- markdown

echo ''
echo 'suggests output options for both -o and --output:'
$harmony --bash-completion pr -- --output 
echo ''
$harmony --bash-completion pr -- -o

echo ''
echo 'suggests project options for both --project:'
$harmony --bash-completion pr -- --project
echo ''
echo 'project opt partial match:'
$harmony --bash-completion pr 4 --project
# no match:
echo '------'
$harmony --bash-completion pr 49 --project
echo '------'
# title match:
$harmony --bash-completion pr test --project

#
# quick command
#
echo ''
echo 'quick command'
echo ''
echo 'bugfix or project flag partial match:'
$harmony --bash-completion quick - quick

echo ''
echo 'project all opts:'
$harmony --bash-completion quick -- --project

echo ''
echo 'project opt partial match:'
$harmony --bash-completion quick 4 --project
# no match:
echo '------'
$harmony --bash-completion quick 49 --project
echo '------'
# title match:
$harmony --bash-completion quick test --project

. ./cleanup.sh
